{
  "$description": "HaHo Design System — Tokens Collection (51 variables × 4 modes)",
  "$modes": ["Light (Rounded)", "Dark (Rounded)", "Light (Sharp)", "Dark (Sharp)"],
  "$note": "Values reference Primitives. Light/Dark controls color mapping. Rounded/Sharp controls radius mapping.",

  "surface": {
    "surfaceNeutral0_5": {
      "lightRounded": "neutrals.0.5",  "darkRounded": "neutrals.9",
      "lightSharp": "neutrals.0.5",    "darkSharp": "neutrals.9"
    },
    "surfaceNeutral2": {
      "lightRounded": "neutrals.2",    "darkRounded": "neutrals.8.5",
      "lightSharp": "neutrals.2",      "darkSharp": "neutrals.8.5"
    },
    "surfaceNeutral3": {
      "lightRounded": "neutrals.3",    "darkRounded": "neutrals.8",
      "lightSharp": "neutrals.3",      "darkSharp": "neutrals.8"
    },
    "surfaceNeutral9": {
      "lightRounded": "neutrals.9",    "darkRounded": "neutrals.0.5",
      "lightSharp": "neutrals.9",      "darkSharp": "neutrals.0.5"
    },
    "surfacePrimary100": {
      "lightRounded": "brand.primary100",   "darkRounded": "brand.secondary100",
      "lightSharp": "brand.primary100",     "darkSharp": "brand.secondary100"
    },
    "surfacePrimary120": {
      "lightRounded": "brand.primary120",   "darkRounded": "neutrals.5",
      "lightSharp": "brand.primary120",     "darkSharp": "neutrals.5"
    },
    "surfaceSecondary100": {
      "lightRounded": "brand.secondary100", "darkRounded": "brand.primary100",
      "lightSharp": "brand.secondary100",   "darkSharp": "brand.primary100"
    }
  },

  "text": {
    "textNeutral9": {
      "lightRounded": "neutrals.9",    "darkRounded": "neutrals.3",
      "lightSharp": "neutrals.9",      "darkSharp": "neutrals.3"
    },
    "textNeutral8": {
      "lightRounded": "neutrals.8",    "darkRounded": "neutrals.2",
      "lightSharp": "neutrals.8",      "darkSharp": "neutrals.2"
    },
    "textNeutral3": {
      "lightRounded": "neutrals.3",    "darkRounded": "neutrals.8",
      "lightSharp": "neutrals.3",      "darkSharp": "neutrals.8"
    },
    "textNeutral2": {
      "lightRounded": "neutrals.2",    "darkRounded": "neutrals.8.5",
      "lightSharp": "neutrals.2",      "darkSharp": "neutrals.8.5"
    },
    "textNeutral0_5": {
      "lightRounded": "neutrals.0.5",  "darkRounded": "neutrals.9",
      "lightSharp": "neutrals.0.5",    "darkSharp": "neutrals.9"
    },
    "textPrimary100": {
      "lightRounded": "brand.primary100",   "darkRounded": "brand.secondary100",
      "lightSharp": "brand.primary100",     "darkSharp": "brand.secondary100"
    },
    "textSecondary100": {
      "lightRounded": "brand.secondary100", "darkRounded": "brand.primary100",
      "lightSharp": "brand.secondary100",   "darkSharp": "brand.primary100"
    },
    "textOpacity75": { "all": "opacity.lg" },
    "textOpacity50": { "all": "opacity.md" }
  },

  "border": {
    "borderNeutral9_5": {
      "lightRounded": "neutrals.9",    "darkRounded": "neutrals.3",
      "lightSharp": "neutrals.9",      "darkSharp": "neutrals.3"
    },
    "borderNeutral8": {
      "lightRounded": "neutrals.8",    "darkRounded": "neutrals.2",
      "lightSharp": "neutrals.8",      "darkSharp": "neutrals.2"
    },
    "borderNeutral3": {
      "lightRounded": "neutrals.3",    "darkRounded": "neutrals.8",
      "lightSharp": "neutrals.3",      "darkSharp": "neutrals.8"
    },
    "borderNeutral2": {
      "lightRounded": "neutrals.2",    "darkRounded": "neutrals.8.5",
      "lightSharp": "neutrals.2",      "darkSharp": "neutrals.8.5"
    },
    "borderNeutral0_5": {
      "lightRounded": "neutrals.0.5",  "darkRounded": "neutrals.9",
      "lightSharp": "neutrals.0.5",    "darkSharp": "neutrals.9"
    },
    "borderSecondary100": { "all": "brand.secondary100" },
    "borderPrimary100": { "all": "brand.primary100" },
    "borderWidthNone": { "all": "borderWidth.none" },
    "borderWidthSm": { "all": "borderWidth.sm" },
    "borderWidthMd": { "all": "borderWidth.md" },
    "borderWidthLg": { "all": "borderWidth.lg" },
    "borderOpacity75": { "all": "opacity.lg" },
    "borderOpacity50": { "all": "opacity.md" }
  },

  "radius": {
    "$note": "Sharp mode resets ALL radius to 0 except full (360). This is the key shape differentiator.",
    "radiusNone":  { "lightRounded": "radius.none", "darkRounded": "radius.none", "lightSharp": "radius.none", "darkSharp": "radius.none" },
    "radiusXxs":   { "lightRounded": "radius.xxs",  "darkRounded": "radius.xxs",  "lightSharp": "radius.none", "darkSharp": "radius.none" },
    "radiusXs":    { "lightRounded": "radius.xs",   "darkRounded": "radius.xs",   "lightSharp": "radius.none", "darkSharp": "radius.none" },
    "radiusSm":    { "lightRounded": "radius.sm",   "darkRounded": "radius.sm",   "lightSharp": "radius.none", "darkSharp": "radius.none" },
    "radiusMd":    { "lightRounded": "radius.md",   "darkRounded": "radius.md",   "lightSharp": "radius.none", "darkSharp": "radius.none" },
    "radiusLg":    { "lightRounded": "radius.lg",   "darkRounded": "radius.lg",   "lightSharp": "radius.none", "darkSharp": "radius.none" },
    "radiusXl":    { "lightRounded": "radius.xl",   "darkRounded": "radius.xl",   "lightSharp": "radius.none", "darkSharp": "radius.none" },
    "radiusXxl":   { "lightRounded": "radius.xxl",  "darkRounded": "radius.xxl",  "lightSharp": "radius.none", "darkSharp": "radius.none" },
    "radiusXxxl":  { "lightRounded": "radius.xxxl", "darkRounded": "radius.xxxl", "lightSharp": "radius.none", "darkSharp": "radius.none" },
    "radiusFull":  { "lightRounded": "radius.full", "darkRounded": "radius.full", "lightSharp": "radius.full", "darkSharp": "radius.full" }
  },

  "spacing": {
    "$note": "Pass-through — spacing is identical across all modes",
    "spacingNone":  "spacing.none",
    "spacingXxxs":  "spacing.xxxs",
    "spacingXxs":   "spacing.xxs",
    "spacingXs":    "spacing.xs",
    "spacingSm":    "spacing.sm",
    "spacingMd":    "spacing.md",
    "spacingLg":    "spacing.lg",
    "spacingXl":    "spacing.xl",
    "spacingXxl":   "spacing.xxl",
    "spacingXxxl":  "spacing.xxxl",
    "spacingXxxxl": "spacing.xxxxl"
  },

  "boolean": {
    "$note": "Light modes = true, Dark modes = false. Used for conditional rendering.",
    "boolean": {
      "lightRounded": true, "darkRounded": false,
      "lightSharp": true,   "darkSharp": false
    }
  }
}
